<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gestor_De_Ventas_Para_Piezas_3D.Vistas.SaleFormPage"
             Title="Registro de Nueva Venta"
             BackgroundColor="#F0F2F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label x:Name="lblTitulo" 
                   Text="Registrar Nueva Venta" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#1F2937" 
                   HorizontalOptions="Center" 
                   Margin="0,10,0,10"/>

            <Frame BackgroundColor="White" CornerRadius="15" Padding="25" HasShadow="True" BorderColor="Transparent">
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto" ColumnSpacing="30" RowSpacing="20">

                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5">
                        <Label Text="ID (Automático)" FontAttributes="Bold" TextColor="Gray"/>
                        <Frame BackgroundColor="#E5E7EB" Padding="10,0" HeightRequest="45" CornerRadius="5" BorderColor="Transparent">
                            <Entry x:Name="txtId" IsReadOnly="True" TextColor="Gray" VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                        <Label Text="Producto (Nombre Venta)" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Frame BackgroundColor="Transparent" BorderColor="LightGray" Padding="10,0" HeightRequest="45" CornerRadius="5">
                            <Entry x:Name="txtProducto" Placeholder="Ej. Figura Iron Man" TextColor="Black" VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="5">
                        <Label Text="Nombre del Empleado" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Frame BackgroundColor="Transparent" BorderColor="LightGray" Padding="10,0" HeightRequest="45" CornerRadius="5">
                            <Entry x:Name="txtEmpleado" Placeholder="Ej. Ana Martinez" TextColor="Black" VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="5">
                        <Label Text="Costo Venta (MXN)" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Frame BackgroundColor="Transparent" BorderColor="LightGray" Padding="10,0" HeightRequest="45" CornerRadius="5">
                            <Entry x:Name="txtCosto" Placeholder="Ej. 500.00" Keyboard="Numeric" TextColor="Black" VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="5">
                        <Label Text="Cliente (Nombre)" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Frame BackgroundColor="Transparent" BorderColor="LightGray" Padding="10,0" HeightRequest="45" CornerRadius="5">
                            <Entry x:Name="txtCliente" Placeholder="Ej. Juan Pérez" TextColor="Black" VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="5">
                        <Label Text="Fecha de Entrega" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Frame BackgroundColor="#F3F4F6" Padding="0" HeightRequest="45" CornerRadius="5" BorderColor="LightGray">
                            <DatePicker x:Name="dpEntrega" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="3" Grid.Column="0" Spacing="5">
                        <Label Text="Teléfono" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Frame BackgroundColor="Transparent" BorderColor="LightGray" Padding="10,0" HeightRequest="45" CornerRadius="5">
                            <Entry x:Name="txtTelefono" Placeholder="Ej. 9981234567" Keyboard="Telephone" TextColor="Black" VerticalOptions="Center"/>
                        </Frame>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Spacing="5">
                        <Label Text="Observaciones" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Frame BackgroundColor="Transparent" BorderColor="LightGray" Padding="10" HeightRequest="80" CornerRadius="5">
                            <Editor x:Name="txtObservaciones" Placeholder="Escribe notas aquí..." TextColor="Black" AutoSize="TextChanges"/>
                        </Frame>
                    </VerticalStackLayout>

                </Grid>
            </Frame>

            <Frame BackgroundColor="White" CornerRadius="15" Padding="25" HasShadow="True" BorderColor="Transparent">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Materiales Extra y Empaque" FontAttributes="Bold" FontSize="18" TextColor="#2D4059"/>
                    <Label Text="Agrega todo lo que se usó (Se descontará del inventario al guardar)" FontSize="12" TextColor="Gray" Margin="0,-10,0,0"/>

                    <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="Transparent" BorderColor="LightGray" Padding="10,0" HeightRequest="65" CornerRadius="5">
                            <Picker x:Name="pckMateriales" Title="Selecciona del inventario..." ItemDisplayBinding="{Binding NombreArticulo}" TextColor="Black" VerticalOptions="Center"/>
                        </Frame>

                        <Frame Grid.Column="1" BackgroundColor="Transparent" BorderColor="LightGray" Padding="10,0" HeightRequest="45" WidthRequest="70" CornerRadius="5">
                            <Entry x:Name="txtCantidadMaterial" Placeholder="Cant." Keyboard="Numeric" TextColor="Black" VerticalOptions="Center"/>
                        </Frame>

                        <Button Grid.Column="2" Text="+" Clicked="OnAgregarMaterialClicked" BackgroundColor="#5F8090" TextColor="White" CornerRadius="8" WidthRequest="45" HeightRequest="45" FontAttributes="Bold" FontSize="20"/>
                    </Grid>

                    <Frame BackgroundColor="#F9FAFB" BorderColor="#E5E7EB" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                        <CollectionView x:Name="cvMaterialesAgregados" HeightRequest="120">
                            <CollectionView.EmptyView>
                                <Label Text="Aún no hay materiales agregados." TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Italic"/>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,5">
                                        <Label Text="{Binding NombreArticulo}" VerticalOptions="Center" TextColor="#374151" FontSize="14"/>
                                        <Label Text="{Binding CantidadUsada, StringFormat='x{0}'}" Grid.Column="1" VerticalOptions="Center" FontAttributes="Bold" TextColor="#2D4059" Margin="0,0,15,0"/>
                                        <ImageButton Grid.Column="2" Source="dotnet_bot.png" BackgroundColor="Transparent" HeightRequest="20" WidthRequest="20" Clicked="OnEliminarMaterialClicked" CommandParameter="{Binding .}"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="20" Margin="0,10,0,20">
                <Button Text="Cancelar" 
                        BackgroundColor="Gray" 
                        TextColor="White" 
                        CornerRadius="25" 
                        WidthRequest="140"
                        HeightRequest="50"
                        FontAttributes="Bold"
                        Clicked="BtnCancelar_Clicked"/>

                <Button x:Name="btnAccion"
                        Text="GUARDAR VENTA" 
                        BackgroundColor="#2C3E50" 
                        TextColor="White" 
                        CornerRadius="25" 
                        WidthRequest="200" 
                        HeightRequest="50"
                        FontAttributes="Bold"
                        Clicked="BtnGuardarVenta_Clicked"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>